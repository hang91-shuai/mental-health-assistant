# ============================================
# 环境变量模板 — 复制为 .env 后填写
# ============================================

# Ollama 服务地址（尉文清部署）
OLLAMA_BASE_URL=http://10.158.82.1:11434
OLLAMA_MODEL=qwen2.5:7b

# ChromaDB 持久化路径
CHROMA_PERSIST_DIR=./data/chroma_db

# BERT 模型（HuggingFace 模型名）
BERT_MODEL=bert-base-chinese

# Flask
FLASK_PORT=5000
FLASK_DEBUG=true

# HuggingFace 镜像（国内加速）
HF_ENDPOINT=https://hf-mirror.com
